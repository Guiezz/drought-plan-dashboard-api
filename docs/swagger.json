                },
                "data": {
                    "type": "string"
                },
                "evaporacao_hm3": {
                    "type": "number"
                },
                "retirada_hm3": {
                    "type": "number"
                },
                "vertimento_hm3": {
                    "type": "number"
                },
                "volume_final_hm3": {
                    "type": "number"
                },
                "volume_inicial_hm3": {
                    "type": "number"
                }
            }
        }
    }
}