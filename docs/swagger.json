{
    "swagger": "2.0",
    "info": {
        "description": "API para gerenciamento e monitoramento de reservatórios hídricos do Ceará.",
        "title": "API do dashboard de apoio a decisão dos planos de secas do estado do Ceará",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "Suporte",
            "email": "guilhermebessanojosaaraujo@gmail.com"
        },
        "version": "1.0"
    },
    "host": "localhost:8000",
    "basePath": "/api",
    "paths": {
        "/api/simulacao/acudes": {
            "get": {
                "tags": [
                    "Simulacao"
                ],
                "summary": "Lista açudes disponíveis para simulação",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/simulador.SimAcude"
                            }
                        }
                    }
                }
            }
        },
        "/api/simulacao/anos": {
            "get": {
                "tags": [
                    "Simulacao"
                ],
                "summary": "Lista anos com vazão cadastrada para um açude",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID do reservatório",
                        "name": "reservatorio_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "array",
                                "items": {
                                    "type": "integer"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/simulacao/run": {
            "post": {
                "description": "Calcula o balanço hídrico mensal com base em dados históricos",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Simulacao"
                ],
                "summary": "Executa a simulação hídrica",
                "parameters": [
                    {
                        "description": "Parâmetros da Simulação",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/simulador.SimulacaoRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/simulador.SimulacaoResponse"
                        }
                    }
                }
            }
        },
        "/reservatorios": {
            "get": {
                "description": "Retorna a lista de todos os reservatórios cadastrados",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Reservatórios"
                ],
                "summary": "Lista reservatórios",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.Reservatorio"
                            }
                        }
                    }
                }
            }
        },
        "/reservatorios/{reservatorioId}/dashboard/summary": {
            "get": {
                "description": "Retorna volume atual, status de seca e resumo de ações recomendadas",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Dashboard"
                ],
                "summary": "Resumo do Dashboard",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID do Reservatório",
                        "name": "reservatorioId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.DashboardResumo"
                        }
                    }
                }
            }
        },
        "/reservatorios/{reservatorioId}/dashboard/volume-chart": {
            "get": {
                "description": "Retorna série histórica de volume e linhas de meta (V.O.)",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Gráficos"
                ],
                "summary": "Dados do Gráfico de Volume",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID do Reservatório",
                        "name": "reservatorioId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.GraficoVolumeData"
                            }
                        }
                    }
                }
            }
        },
        "/reservatorios/{reservatorioId}/funceme-backfill": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Busca dados históricos de volume desde a data informada e insere no banco, evitando duplicatas. Requer token de administrador.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Admin"
                ],
                "summary": "Backfill de dados históricos da FUNCEME",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID do Reservatório",
                        "name": "reservatorioId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Data de início no formato YYYY-MM-DD",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/controller.BackfillRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/controller.BackfillResponse"
                        }
                    },
                    "400": {
                        "description": "data_inicio inválido ou ausente",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "401": {
                        "description": "token não fornecido",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "403": {
                        "description": "sem permissão",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "erro interno",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/reservatorios/{reservatorioId}/gatilhos-pgps": {
            "get": {
                "description": "Retorna os gatilhos mensais do PGPS (meta1v, meta2v, meta3v) em hm³ para cada mês",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Reservatórios"
                ],
                "summary": "Gatilhos do PGPS",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID do Reservatório",
                        "name": "reservatorioId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.GatilhosPGPSResponse"
                        }
                    }
                }
            }
        },
        "/reservatorios/{reservatorioId}/history": {
            "get": {
                "description": "Retorna tabela completa de monitoramento com status de seca calculado",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Monitoramento"
                ],
                "summary": "Histórico Tabular",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID do Reservatório",
                        "name": "reservatorioId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.HistoricoTabela"
                            }
                        }
                    }
                }
            }
        },
        "/reservatorios/{reservatorioId}/identification": {
            "get": {
                "description": "Retorna dados cadastrais, URLs de imagens e localização",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Reservatórios"
                ],
                "summary": "Identificação e Localização",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID do Reservatório",
                        "name": "reservatorioId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.ReservatorioDetalhes"
                        }
                    }
                }
            }
        },
        "/reservatorios/{reservatorioId}/responsibles": {
            "get": {
                "description": "Lista as entidades e pessoas responsáveis pelo reservatório",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Cadastros Auxiliares"
                ],
                "summary": "Responsáveis",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID do Reservatório",
                        "name": "reservatorioId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.Responsavel"
                            }
                        }
                    }
                }
            }
        },
        "/reservatorios/{reservatorioId}/water-balance": {
            "get": {
                "description": "Retorna dados formatados para os 3 gráficos: Balanço Mensal, Demanda e Oferta",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Gráficos"
                ],
                "summary": "Gráficos de Balanço Hídrico",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID do Reservatório",
                        "name": "reservatorioId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.BalancoHidricoResumo"
                        }
                    }
                }
            }
        },
        "/reservatorios/{reservatorioId}/water-uses": {
            "get": {
                "description": "Lista os usos e vazões cadastradas",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Cadastros Auxiliares"
                ],
                "summary": "Usos da Água",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID do Reservatório",
                        "name": "reservatorioId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.UsoAgua"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "controller.BackfillRequest": {
            "type": "object",
            "required": [
                "data_inicio"
            ],
            "properties": {
                "data_inicio": {
                    "type": "string"
                }
            }
        },
        "controller.BackfillResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Backfill concluído"
                },
                "registros": {
                    "type": "integer",
                    "example": 1250
                }
            }
        },
        "model.BalancoHidricoResumo": {
            "type": "object",
            "properties": {
                "balancoMensal": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "additionalProperties": true
                    }
                },
                "composicaoDemanda": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "additionalProperties": true
                    }
                },
                "ofertaDemanda": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "additionalProperties": true
                    }
                }
            }
        },
        "model.DashboardResumo": {
            "type": "object",
            "properties": {
                "dataUltimaMedicao": {
                    "type": "string"
                },
                "diasDesdeUltimaMudanca": {
                    "type": "integer"
                },
                "estadoAtualSeca": {
                    "type": "string"
                },
                "medidasRecomendadas": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.PlanoAcaoResumo"
                    }
                },
                "volumeAtualHm3": {
                    "type": "number"
                },
                "volumePercentual": {
                    "type": "number"
                }
            }
        },
        "model.GatilhoMensalPGPS": {
            "type": "object",
            "properties": {
                "alerta_hm3": {
                    "type": "number"
                },
                "mes_nome": {
                    "type": "string"
                },
                "mes_num": {
                    "type": "integer"
                },
                "normal_hm3": {
                    "type": "number"
                },
                "seca_hm3": {
                    "type": "number"
                },
                "seca_severa_hm3": {
                    "type": "number"
                }
            }
        },
        "model.GatilhosPGPSResponse": {
            "type": "object",
            "properties": {
                "capacidade_hm3": {
                    "type": "number"
                },
                "gatilhos": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.GatilhoMensalPGPS"
                    }
                },
                "nome_reservatorio": {
                    "type": "string"
                },
                "reservatorio_id": {
                    "type": "integer"
                }
            }
        },
        "model.GraficoVolumeData": {
            "type": "object",
            "properties": {
                "Data": {
                    "description": "Frontend espera \"Data\" com D maiúsculo",
                    "type": "string"
                },
                "meta1": {
                    "type": "number"
                },
                "meta2": {
                    "type": "number"
                },
                "meta3": {
                    "type": "number"
                },
                "volume": {
                    "type": "number"
                }
            }
        },
        "model.HistoricoTabela": {
            "type": "object",
            "properties": {
                "Data": {
                    "description": "Ex: \"25/12/2023\"",
                    "type": "string"
                },
                "Estado de Seca": {
                    "description": "Com espaços",
                    "type": "string"
                },
                "Volume (hm3)": {
                    "description": "Com unidade e parênteses",
                    "type": "number"
                }
            }
        },
        "model.PlanoAcaoResumo": {
            "type": "object",
            "properties": {
                "acao": {
                    "type": "string"
                },
                "descricao": {
                    "type": "string"
                },
                "responsaveis": {
                    "type": "string"
                }
            }
        },
        "model.Reservatorio": {
            "type": "object",
            "properties": {
                "capacidade_hm3": {
                    "type": "number"
                },
                "codigo_funceme": {
                    "type": "string"
                },
                "descricao": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "lat": {
                    "type": "number"
                },
                "long": {
                    "type": "number"
                },
                "municipio": {
                    "type": "string"
                },
                "nome": {
                    "type": "string"
                },
                "nome_imagem": {
                    "type": "string"
                },
                "nome_imagem_usos": {
                    "type": "string"
                }
            }
        },
        "model.ReservatorioDetalhes": {
            "type": "object",
            "properties": {
                "descricao": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "lat": {
                    "type": "number"
                },
                "long": {
                    "type": "number"
                },
                "municipio": {
                    "type": "string"
                },
                "nome": {
                    "type": "string"
                },
                "url_imagem": {
                    "type": "string"
                },
                "url_imagem_usos": {
                    "type": "string"
                }
            }
        },
        "model.Responsavel": {
            "type": "object",
            "properties": {
                "cargo": {
                    "type": "string"
                },
                "grupo": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "nome": {
                    "type": "string"
                },
                "organizacao": {
                    "type": "string"
                },
                "reservatorio_id": {
                    "type": "integer"
                },
                "setor": {
                    "type": "string"
                }
            }
        },
        "model.UsoAgua": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "integer"
                },
                "reservatorio_id": {
                    "type": "integer"
                },
                "uso": {
                    "type": "string"
                },
                "vazao_escassez": {
                    "type": "number"
                },
                "vazao_normal": {
                    "type": "number"
                }
            }
        },
        "simulador.CenarioSimulacao": {
            "type": "object",
            "properties": {
                "anos": {
                    "description": "[1915] ou [2012,2013,2014,2015,2016,2017]",
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "nome": {
                    "description": "\"Seca 1915\", \"2012-2017\", etc.",
                    "type": "string"
                }
            }
        },
        "simulador.SimAcude": {
            "type": "object",
            "properties": {
                "capacidade_m3": {
                    "description": "Coluna CAPAC (m³)",
                    "type": "number"
                },
                "codigo": {
                    "description": "Coluna COD",
                    "type": "integer"
                },
                "estacao_evap_id": {
                    "description": "Coluna Est. Evap.",
                    "type": "integer"
                },
                "municipio": {
                    "description": "Coluna MUNICIPIO",
                    "type": "string"
                },
                "nome": {
                    "description": "Coluna CORPO",
                    "type": "string"
                }
            }
        },
        "simulador.SimulacaoRequest": {
            "type": "object",
            "properties": {
                "cenarios": {
                    "description": "Multi-cenário: se preenchido, executa simulação para cada cenário",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/simulador.CenarioSimulacao"
                    }
                },
                "data_fim": {
                    "type": "string"
                },
                "data_inicio": {
                    "type": "string"
                },
                "demandas_mensais": {
                    "description": "Opcionais (se quiser simular cenários manuais)",
                    "type": "array",
                    "items": {
                        "type": "number"
                    }
                },
                "reservatorio_id": {
                    "type": "integer"
                },
                "usar_media_historica": {
                    "description": "Se true, usa médias históricas do banco. Se false, usa os arrays abaixo.",
                    "type": "boolean"
                },
                "volume_inicial": {
                    "description": "Em hm³",
                    "type": "number"
                }
            }
        },
        "simulador.SimulacaoResponse": {
            "type": "object",
            "properties": {
                "frequencia_nao_atendida": {
                    "type": "number"
                },
                "resultados": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/simulador.SimulacaoResultado"
                    }
                },
                "volume_final": {
                    "type": "number"
                }
            }
        },
        "simulador.SimulacaoResultado": {
            "type": "object",
            "properties": {
                "afluencia_hm3": {
                    "type": "number"
                },
                "alerta": {
